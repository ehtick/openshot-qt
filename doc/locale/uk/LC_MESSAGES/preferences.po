# Translated with gpt-4.1-mini
#: ../preferences.rst:257
msgid "Values"
msgstr "Значення"

# Translated with gpt-4.1-mini
#: ../preferences.rst:259
msgid "**Recent Folder**"
msgstr "**Остання папка**"

# Translated with gpt-4.1-mini
#: ../preferences.rst:259
msgid ""
"The last folder used for this same operation. Project folders, Import "
