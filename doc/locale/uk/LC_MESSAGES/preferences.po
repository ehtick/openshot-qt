msgstr "Увімкнути автозбереження"

# Translated with gpt-4.1-mini
#: ../preferences.rst:125
msgid "Enabled"
msgstr "Увімкнено"

# Translated with gpt-4.1-mini
#: ../preferences.rst:126
msgid "Autosave Interval (minutes)"
msgstr "Інтервал автозбереження (хвилини)"

# Translated with gpt-4.1-mini
#: ../preferences.rst:126
