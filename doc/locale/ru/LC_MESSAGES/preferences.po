msgid "Enabled"
msgstr "Включено"

# Translated with gpt-4.1-mini
#: ../preferences.rst:126
msgid "Autosave Interval (minutes)"
msgstr "Интервал автосохранения (минуты)"

# Translated with gpt-4.1-mini
#: ../preferences.rst:126
msgid "3"
msgstr "3"

# Translated with gpt-4.1-mini
#: ../preferences.rst:127
