#: ../main_window.rst:42 ../main_window.rst:107
msgid "Zoom Slider"
msgstr "Klizač zumiranja"

# Translated with gpt-4.1-mini
#: ../main_window.rst:42
msgid ""
"This slider will adjust the time-scale of your timeline. Drag the left or "
"right edge to zoom in or out. Drag the blue area to scroll the timeline left "
"or right. Clips and transitions are displayed as simple rectangles, to give "
"you context for adjusting the zoom to specific clips."
msgstr ""
"Ovim klizačem podešavate vremenski raspon vaše vremenske linije. Povucite "
"lijevi ili desni rub za uvećavanje ili umanjenje. Povucite plavo područje za "
"pomicanje vremenske linije lijevo ili desno. Isječci i prijelazi prikazani "
"su kao jednostavni pravokutnici, kako biste lakše prilagodili zum određenim "
"isječcima."

